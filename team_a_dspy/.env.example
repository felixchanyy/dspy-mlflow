# LLM Configuration
LLM_BASE_URL=http://x.x.x.x:xxxx/v1
LLM_MODEL_NAME=MiniMax-M2.1-AWQ
LLM_API_KEY=not-required

# Elasticsearch Configuration
ES_HOST=https://x.x.x.x:xxxx
ES_USERNAME=
ES_PASSWORD=
ES_INDEX=gkg
ES_VERIFY_SSL=False
ES_REQUEST_TIMEOUT_SECONDS=60

# ChromaDB Configuration
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=gkg_mapping
SCHEMA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Telemetry
ANONYMIZED_TELEMETRY=False

# Sandbox ES for testing generated queries safely
SANDBOX_ES_HOST=http://sandbox_es:9200
