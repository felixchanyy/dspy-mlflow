          "query": {
            "bool": {
              "must": [
                {
                  "term": {
                    "V2Locations.CountryCode.keyword": "US"
                  }
                },
                {
                  "terms": {
                    "V2EnhancedThemes.V2Theme.keyword": [
                      "GENERAL_GOVERNMENT",
                      "EPU_POLICY_POLITICAL",
                      "DEMOCRACY"
                    ]
                  }
                },
                {
                  "range": {
                    "V21Date": {
                      "gte": "now-1d/d",
                      "lte": "now/d"
