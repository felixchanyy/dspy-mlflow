# Elasticsearch
ES_HOST=https://x.x.x.x:xxxx
ES_USERNAME=
ES_PASSWORD=
ES_INDEX=gkg
ES_VERIFY_SSL=false

# LLM
LLM_BASE_URL=http://x.x.x.x:xxxx/v1
LLM_MODEL_NAME=MiniMax-M2.1-AWQ
LLM_API_KEY=not-required

# Safety limits
MAX_RESULT_DOCS=20
MAX_AGG_BUCKETS=50

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Sandbox Elasticsearch
SANDBOX_ES_HOST=http://sandbox_elasticsearch:9200
SANDBOX_ES_USERNAME=elastic
SANDBOX_ES_PASSWORD=changeme
SANDBOX_ES_INDEX=gkg
SANDBOX_ES_VERIFY_SSL=false